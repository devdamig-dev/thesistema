# GastroPilot AI — variables de entorno
# Copiar a .env.local y completar.

# ------------------------------------------------------------------------------
# Modo de ejecución
# ------------------------------------------------------------------------------
# "demo"     → la app consume mock-data.ts (no requiere Supabase). Default.
# "database" → la app consume Supabase. Requiere URL + ANON_KEY.
NEXT_PUBLIC_APP_MODE=demo

# ------------------------------------------------------------------------------
# Supabase
# ------------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Sólo para scripts server-side (seed, migraciones manuales).
# NUNCA exponer en el cliente.
SUPABASE_SERVICE_ROLE_KEY=

# ------------------------------------------------------------------------------
# WhatsApp Cloud API (sprint 2)
# ------------------------------------------------------------------------------
# Token compartido con Meta para verificar el webhook al registrarlo.
META_VERIFY_TOKEN=gastropilot-dev

# ------------------------------------------------------------------------------
# Anthropic Claude (sprint 2 · extracción IA)
# ------------------------------------------------------------------------------
# Opcional. Si no está, usamos el extractor heurístico de lib/ai/heuristic.ts.
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL_ID=claude-haiku-4-5-20251001

# ------------------------------------------------------------------------------
# OCR · Smart Invoices
# ------------------------------------------------------------------------------
# Provider explícito. Si no está, decide en orden: mindee > google-vision > mock.
# OCR_PROVIDER=mock | mindee | google-vision

# Mindee Invoice API (opcional · provider real)
# MINDEE_API_KEY=

# Google Cloud Vision (opcional · provider real)
# GOOGLE_VISION_API_KEY=
